#!/bin/sh
set -eu

# Push the issue tracker along with the code.
#
# The issue database goes to refs/dolt/data on the remote. That ref — not the
# tracked .beads/issues.jsonl — is what a fresh clone reads: `bd bootstrap`
# prefers sync.remote and falls back to the JSONL only fourth. So a push that
# skips this step leaves collaborators on a backlog that can be days old, with
# nothing on screen to suggest it.

. "$(dirname "$0")/beads-hook.sh"

push_beads_state
