#!/bin/sh
set -eu

warn() { printf "FAIL: %s\n" "$1"; }
ok()   { printf "OK:   %s\n" "$1"; }

# Tests run inside a container, never against the host filesystem.
. "$(dirname "$0")/containerized-tests.sh"

# go-installed tools (gofumpt, golangci-lint) live in $(go env GOPATH)/bin, which
# an interactive shell has on PATH but a hook invoked by an editor or a sandboxed
# process may not. Add it so the checks below find them wherever the hook runs.
command -v go >/dev/null 2>&1 && PATH="$(go env GOPATH)/bin:$PATH"

# --- check all binaries first, report all missing together ------------------
CHECK_CMD_TRUE=true
check_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        warn "$1 not found — install: $2"
        CHECK_CMD_TRUE=false
    fi
}

check_cmd gofumpt "go install mvdan.cc/gofumpt@latest"
check_cmd golangci-lint "go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.64.8"
check_cmd go "install Go from https://go.dev/dl/"
check_cmd node "install Node.js from https://nodejs.org/"
check_cmd npm "install Node.js from https://nodejs.org/"
check_cmd docker "start OrbStack or Docker Desktop — tests run in a container"

if [ ! -d frontend/node_modules ]; then
    warn "frontend/node_modules not found — run: cd frontend && npm ci"
    CHECK_CMD_TRUE=false
fi

if [ "$CHECK_CMD_TRUE" = false ]; then
    printf "\nPre-commit hook FAILED — install missing tools above and try again.\n"
    exit 1
fi

# --- 1. gofumpt -------------------------------------------------------------
UNFMT=$(gofumpt -l . 2>&1) || true
if [ -n "$UNFMT" ]; then
    warn "gofumpt — the following files need formatting:"
    printf "%s\n" "$UNFMT"
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "gofumpt"

# --- 2. golangci-lint -------------------------------------------------------
if ! golangci-lint run ./... 2>&1; then
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "golangci-lint"

# --- 3. go test (in a container) --------------------------------------------
if ! go_test_containerized; then
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "go test -race (container)"

# --- 4. frontend format check -----------------------------------------------
if ! (cd frontend && npm run format:check 2>&1); then
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "prettier --check"

# --- 5. frontend lint -------------------------------------------------------
if ! (cd frontend && npm run lint 2>&1); then
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "eslint"

# --- 6. frontend typecheck --------------------------------------------------
if ! (cd frontend && npm run typecheck 2>&1); then
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "tsc --noEmit"

# --- 7. frontend test (in a container) --------------------------------------
if ! vitest_containerized; then
    printf "\nPre-commit hook FAILED. Fix the issues above and try again.\n"
    exit 1
fi
ok "vitest (container)"

# --- 8. beads: materialise the issue snapshot into this commit ---------------
# Last, deliberately: a gate that fails above must not leave .beads/issues.jsonl
# rewritten and staged for a commit that never happens.
. "$(dirname "$0")/beads-hook.sh"
export_beads_snapshot
ok "beads export"

printf "\nAll checks passed.\n"
