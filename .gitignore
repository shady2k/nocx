# --- Personal / per-contributor (never shared) ---
.claude/settings.local.json
**/config.user.toml
**/config.user.yaml
.env
.env.*

# --- BMAD resolved config: installer-generated, bakes in personal identity ---
# Source of truth is the committed *.toml. Regenerate via the BMAD installer.
_bmad/core/config.yaml
_bmad/bmm/config.yaml

# --- BMAD working scratch: canonical outputs are promoted to docs/ ---
_bmad-output/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# --- Build output (grows with the app) ---
/build/
/dist/
/bin/
node_modules/

# --- Go ---
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/go/build/
vendor/

# --- Wails ---
frontend/dist/*
!frontend/dist/index.html

# --- Node / frontend ---
frontend/node_modules/

# --- Beads / Dolt files (added by bd init) ---
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/
